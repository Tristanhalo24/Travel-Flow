<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="TravelFlow_Definitions" targetNamespace="http://travelflow.al/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <bpmn:collaboration id="TravelFlow_Collaboration" name="TravelFlow — Journey Beyond the Horizon">
    <bpmn:participant id="Pool_Booking" name="CLIENT — Ticket Booking Process" processRef="Process_Booking" />
    <bpmn:participant id="Pool_Cancellation" name="CLIENT — Booking Cancellation Process" processRef="Process_Cancellation" />
    <bpmn:participant id="Pool_Rental" name="CLIENT — Vehicle Rental Process" processRef="Process_Rental" />
    <bpmn:participant id="Pool_Driver" name="DRIVER — Ticket Validation Process" processRef="Process_Driver" />
    <bpmn:participant id="Pool_Admin" name="ADMIN — Platform Management Process" processRef="Process_Admin" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Booking" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Booking">
      <bpmn:lane id="Lane_System_Booking" name="System">
        <bpmn:flowNodeRef>Task_ValidateCredentials</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CalcPriceSegment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AssignRandomSeat</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_QueryTrips</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_LockSeatGenerateCode</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Client_Booking" name="Client">
        <bpmn:flowNodeRef>Start_Visit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegisterLogin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_AlreadyRegistered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SearchTrip</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_TripsFound</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SelectTripCard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SelectDestStop</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_SeatSelection</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PickSeatManual</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReviewFeeConfirm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_BookingConfirmed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FillRegisterDetails</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Visit" name="Visit Platform">
      <bpmn:outgoing>Flow_B01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_RegisterLogin" name="Register / Login">
      <bpmn:incoming>Flow_B01</bpmn:incoming>
      <bpmn:outgoing>Flow_B02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_AlreadyRegistered" name="Already&#10;Registered?">
      <bpmn:incoming>Flow_B02</bpmn:incoming>
      <bpmn:outgoing>Flow_B03_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_B03_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ValidateCredentials" name="Validate Credentials&#10;Create Session (RBAC)&#10;Auto-login if new user">
      <bpmn:incoming>Flow_B04</bpmn:incoming>
      <bpmn:incoming>Flow_B03_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_B05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_SearchTrip" name="Search Trip&#10;(From, To, Date)">
      <bpmn:incoming>Flow_B05</bpmn:incoming>
      <bpmn:outgoing>Flow_B06</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_TripsFound" name="Trips Found?">
      <bpmn:incoming>Flow_B07</bpmn:incoming>
      <bpmn:outgoing>Flow_B08_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_B08_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_SelectTripCard" name="Select Trip Card&#10;(Route, Time, Bus, Price)">
      <bpmn:incoming>Flow_B08_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_B09</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_SelectDestStop" name="Select Destination Stop&#10;(Confirm Booking disabled&#10;until stop chosen)">
      <bpmn:incoming>Flow_B09</bpmn:incoming>
      <bpmn:outgoing>Flow_B10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_CalcPriceSegment" name="Calculate Price by Segment&#10;(Ticket + Site Fee 100 lek&#10;+ Seat Fee if manual)">
      <bpmn:incoming>Flow_B10</bpmn:incoming>
      <bpmn:outgoing>Flow_B11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_SeatSelection" name="Seat&#10;Selection?">
      <bpmn:incoming>Flow_B11</bpmn:incoming>
      <bpmn:outgoing>Flow_B12_Manual</bpmn:outgoing>
      <bpmn:outgoing>Flow_B12_Random</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_PickSeatManual" name="Pick Seat on Map&#10;(Red=Occupied, Green=Free&#10;Teal=Selected) — Manual">
      <bpmn:incoming>Flow_B12_Manual</bpmn:incoming>
      <bpmn:outgoing>Flow_B13_M</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AssignRandomSeat" name="Assign Lowest Available&#10;Seat Number Automatically&#10;(No extra charge)">
      <bpmn:incoming>Flow_B12_Random</bpmn:incoming>
      <bpmn:outgoing>Flow_B13_R</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ReviewFeeConfirm" name="Show Fee Breakdown&#10;&#38; Confirm Booking&#10;(Itemised: Ticket + Fees)">
      <bpmn:incoming>Flow_B13_M</bpmn:incoming>
      <bpmn:incoming>Flow_B13_R</bpmn:incoming>
      <bpmn:outgoing>Flow_B14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_BookingConfirmed" name="Booking&#10;Confirmed">
      <bpmn:incoming>Flow_B15</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_FillRegisterDetails" name="Fill Name, Email,&#10;Password (min 6 chars)">
      <bpmn:incoming>Flow_B03_No</bpmn:incoming>
      <bpmn:outgoing>Flow_B04</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_QueryTrips" name="Query Trips Table&#10;/ Run autoTrips if empty&#10;(within 500ms)">
      <bpmn:incoming>Flow_B06</bpmn:incoming>
      <bpmn:outgoing>Flow_B07</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_LockSeatGenerateCode" name="Lock Seat in bookedSeats&#10;Generate Unique Booking Code&#10;Send Toast + Email (QR e-ticket)">
      <bpmn:incoming>Flow_B14</bpmn:incoming>
      <bpmn:outgoing>Flow_B15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_B01" sourceRef="Start_Visit" targetRef="Task_RegisterLogin" />
    <bpmn:sequenceFlow id="Flow_B02" sourceRef="Task_RegisterLogin" targetRef="GW_AlreadyRegistered" />
    <bpmn:sequenceFlow id="Flow_B03_No" name="No" sourceRef="GW_AlreadyRegistered" targetRef="Task_FillRegisterDetails" />
    <bpmn:sequenceFlow id="Flow_B03_Yes" name="Yes" sourceRef="GW_AlreadyRegistered" targetRef="Task_ValidateCredentials" />
    <bpmn:sequenceFlow id="Flow_B04" sourceRef="Task_FillRegisterDetails" targetRef="Task_ValidateCredentials" />
    <bpmn:sequenceFlow id="Flow_B05" sourceRef="Task_ValidateCredentials" targetRef="Task_SearchTrip" />
    <bpmn:sequenceFlow id="Flow_B08_No" name="No trips — retry" sourceRef="GW_TripsFound" targetRef="Task_SearchTrip" />
    <bpmn:sequenceFlow id="Flow_B06" sourceRef="Task_SearchTrip" targetRef="Task_QueryTrips" />
    <bpmn:sequenceFlow id="Flow_B07" sourceRef="Task_QueryTrips" targetRef="GW_TripsFound" />
    <bpmn:sequenceFlow id="Flow_B08_Yes" name="Yes" sourceRef="GW_TripsFound" targetRef="Task_SelectTripCard" />
    <bpmn:sequenceFlow id="Flow_B09" sourceRef="Task_SelectTripCard" targetRef="Task_SelectDestStop" />
    <bpmn:sequenceFlow id="Flow_B10" sourceRef="Task_SelectDestStop" targetRef="Task_CalcPriceSegment" />
    <bpmn:sequenceFlow id="Flow_B11" sourceRef="Task_CalcPriceSegment" targetRef="GW_SeatSelection" />
    <bpmn:sequenceFlow id="Flow_B12_Manual" name="Manual" sourceRef="GW_SeatSelection" targetRef="Task_PickSeatManual" />
    <bpmn:sequenceFlow id="Flow_B12_Random" name="Random" sourceRef="GW_SeatSelection" targetRef="Task_AssignRandomSeat" />
    <bpmn:sequenceFlow id="Flow_B13_M" sourceRef="Task_PickSeatManual" targetRef="Task_ReviewFeeConfirm" />
    <bpmn:sequenceFlow id="Flow_B13_R" sourceRef="Task_AssignRandomSeat" targetRef="Task_ReviewFeeConfirm" />
    <bpmn:sequenceFlow id="Flow_B14" sourceRef="Task_ReviewFeeConfirm" targetRef="Task_LockSeatGenerateCode" />
    <bpmn:sequenceFlow id="Flow_B15" sourceRef="Task_LockSeatGenerateCode" targetRef="End_BookingConfirmed" />
  </bpmn:process>
  <bpmn:process id="Process_Cancellation" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Cancellation">
      <bpmn:lane id="Lane_System_Cancel" name="System">
        <bpmn:flowNodeRef>Task_UpdateStatusCancelled</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Client_Cancel" name="Client">
        <bpmn:flowNodeRef>Start_ViewAccount_Cancel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ClickCancel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConfirmCancelDialog</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_CancelConfirmed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_BookingCancelled</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_NoChange</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_ViewAccount_Cancel" name="View My Account">
      <bpmn:outgoing>Flow_C01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_ClickCancel" name="Click Cancel on Booking&#10;(Hidden for already-cancelled&#10;or post-departure bookings)">
      <bpmn:incoming>Flow_C01</bpmn:incoming>
      <bpmn:outgoing>Flow_C02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ConfirmCancelDialog" name="Confirm Cancellation Dialog&#10;&#39;Are you sure? This action&#10;cannot be undone.&#39;">
      <bpmn:incoming>Flow_C02</bpmn:incoming>
      <bpmn:outgoing>Flow_C03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_CancelConfirmed" name="Confirmed?">
      <bpmn:incoming>Flow_C03</bpmn:incoming>
      <bpmn:outgoing>Flow_C04_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_C04_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_UpdateStatusCancelled" name="Update status=&#39;cancelled&#39;&#10;Release Seat from bookedSeats&#10;Show Toast Notification">
      <bpmn:incoming>Flow_C04_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_C05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_BookingCancelled" name="Booking&#10;Cancelled">
      <bpmn:incoming>Flow_C05</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_NoChange" name="No Change&#10;(Go Back)">
      <bpmn:incoming>Flow_C04_No</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_C01" sourceRef="Start_ViewAccount_Cancel" targetRef="Task_ClickCancel" />
    <bpmn:sequenceFlow id="Flow_C02" sourceRef="Task_ClickCancel" targetRef="Task_ConfirmCancelDialog" />
    <bpmn:sequenceFlow id="Flow_C03" sourceRef="Task_ConfirmCancelDialog" targetRef="GW_CancelConfirmed" />
    <bpmn:sequenceFlow id="Flow_C04_Yes" name="Yes" sourceRef="GW_CancelConfirmed" targetRef="Task_UpdateStatusCancelled" />
    <bpmn:sequenceFlow id="Flow_C04_No" name="No (Go Back)" sourceRef="GW_CancelConfirmed" targetRef="End_NoChange" />
    <bpmn:sequenceFlow id="Flow_C05" sourceRef="Task_UpdateStatusCancelled" targetRef="End_BookingCancelled" />
  </bpmn:process>
  <bpmn:process id="Process_Rental" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Rental">
      <bpmn:lane id="Lane_System_Rental" name="System">
        <bpmn:flowNodeRef>Task_CalcDaysTotalInsert</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Client_Rental" name="Client">
        <bpmn:flowNodeRef>Start_BrowseRental</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ApplyFilters</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SelectCarEnterDates</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_DatesValid</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReviewTotalConfirm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_RentalConfirmed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_RentalDateError</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_BrowseRental" name="Browse Rental&#10;Catalogue">
      <bpmn:outgoing>Flow_R01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_ApplyFilters" name="Apply Filters&#10;(Category, Fuel,&#10;Transmission)">
      <bpmn:incoming>Flow_R01</bpmn:incoming>
      <bpmn:outgoing>Flow_R02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_SelectCarEnterDates" name="Select Car &#38; Enter&#10;Pickup / Return Dates">
      <bpmn:incoming>Flow_R02</bpmn:incoming>
      <bpmn:outgoing>Flow_R03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_DatesValid" name="Return &#62; Pickup?">
      <bpmn:incoming>Flow_R03</bpmn:incoming>
      <bpmn:outgoing>Flow_R04_Valid</bpmn:outgoing>
      <bpmn:outgoing>Flow_R04_Invalid</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_CalcDaysTotalInsert" name="Calculate Days &#38; Total Price&#10;Insert Rentals Record (confirmed)&#10;Set car available=0">
      <bpmn:incoming>Flow_R04_Valid</bpmn:incoming>
      <bpmn:outgoing>Flow_R05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ReviewTotalConfirm" name="Review Total Price&#10;&#38; Confirm Rental">
      <bpmn:incoming>Flow_R05</bpmn:incoming>
      <bpmn:outgoing>Flow_R06</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_RentalConfirmed" name="Rental&#10;Confirmed">
      <bpmn:incoming>Flow_R06</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_RentalDateError" name="Validation Error&#10;(Return ≤ Pickup)">
      <bpmn:incoming>Flow_R04_Invalid</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_R01" sourceRef="Start_BrowseRental" targetRef="Task_ApplyFilters" />
    <bpmn:sequenceFlow id="Flow_R02" sourceRef="Task_ApplyFilters" targetRef="Task_SelectCarEnterDates" />
    <bpmn:sequenceFlow id="Flow_R03" sourceRef="Task_SelectCarEnterDates" targetRef="GW_DatesValid" />
    <bpmn:sequenceFlow id="Flow_R04_Valid" name="Valid" sourceRef="GW_DatesValid" targetRef="Task_CalcDaysTotalInsert" />
    <bpmn:sequenceFlow id="Flow_R04_Invalid" name="Invalid&#10;(Return ≤ Pickup)" sourceRef="GW_DatesValid" targetRef="End_RentalDateError" />
    <bpmn:sequenceFlow id="Flow_R05" sourceRef="Task_CalcDaysTotalInsert" targetRef="Task_ReviewTotalConfirm" />
    <bpmn:sequenceFlow id="Flow_R06" sourceRef="Task_ReviewTotalConfirm" targetRef="End_RentalConfirmed" />
  </bpmn:process>
  <bpmn:process id="Process_Driver" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Driver">
      <bpmn:lane id="Lane_System_Driver" name="System">
        <bpmn:flowNodeRef>Task_QueryBookingsByCode</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShowErrorCode</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Driver_Portal" name="Driver">
        <bpmn:flowNodeRef>Start_LoginDriver</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ViewDriverPortal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_CodeValid</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_MorePassengers</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_ValidationComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EnterPassengerCode</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ShowPassengerInfo</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_LoginDriver" name="Login as Driver">
      <bpmn:outgoing>Flow_D01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_ViewDriverPortal" name="View Driver Portal&#10;(Trips, Bus Plate,&#10;Passenger Count)">
      <bpmn:incoming>Flow_D01</bpmn:incoming>
      <bpmn:outgoing>Flow_D02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_QueryBookingsByCode" name="Query Bookings by Code&#10;Update status=&#39;used&#39; if valid&#10;(uppercase match)">
      <bpmn:incoming>Flow_D03</bpmn:incoming>
      <bpmn:outgoing>Flow_D04</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_CodeValid" name="Code Valid?">
      <bpmn:incoming>Flow_D04</bpmn:incoming>
      <bpmn:outgoing>Flow_D05_Valid</bpmn:outgoing>
      <bpmn:outgoing>Flow_D05_Invalid</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_MorePassengers" name="More&#10;Passengers?">
      <bpmn:incoming>Flow_D06_V</bpmn:incoming>
      <bpmn:incoming>Flow_D06_I</bpmn:incoming>
      <bpmn:outgoing>Flow_D_Loop</bpmn:outgoing>
      <bpmn:outgoing>Flow_D07_Done</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_ValidationComplete" name="All Passengers&#10;Validated">
      <bpmn:incoming>Flow_D07_Done</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_EnterPassengerCode" name="Enter Passenger&#10;Booking Code&#10;(Auto-focus, no refresh)">
      <bpmn:incoming>Flow_D02</bpmn:incoming>
      <bpmn:incoming>Flow_D_Loop</bpmn:incoming>
      <bpmn:outgoing>Flow_D03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ShowPassengerInfo" name="Show Passenger Info&#10;(Name, Seat No, Stop, Route)&#10;Green Panel">
      <bpmn:incoming>Flow_D05_Valid</bpmn:incoming>
      <bpmn:outgoing>Flow_D06_V</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ShowErrorCode" name="Show ERROR Panel&#10;(Not Found / Already Used&#10;/ Trip Mismatch) — Red">
      <bpmn:incoming>Flow_D05_Invalid</bpmn:incoming>
      <bpmn:outgoing>Flow_D06_I</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_D01" sourceRef="Start_LoginDriver" targetRef="Task_ViewDriverPortal" />
    <bpmn:sequenceFlow id="Flow_D02" sourceRef="Task_ViewDriverPortal" targetRef="Task_EnterPassengerCode" />
    <bpmn:sequenceFlow id="Flow_D03" sourceRef="Task_EnterPassengerCode" targetRef="Task_QueryBookingsByCode" />
    <bpmn:sequenceFlow id="Flow_D04" sourceRef="Task_QueryBookingsByCode" targetRef="GW_CodeValid" />
    <bpmn:sequenceFlow id="Flow_D05_Valid" name="Valid" sourceRef="GW_CodeValid" targetRef="Task_ShowPassengerInfo" />
    <bpmn:sequenceFlow id="Flow_D05_Invalid" name="Invalid" sourceRef="GW_CodeValid" targetRef="Task_ShowErrorCode" />
    <bpmn:sequenceFlow id="Flow_D06_V" sourceRef="Task_ShowPassengerInfo" targetRef="GW_MorePassengers" />
    <bpmn:sequenceFlow id="Flow_D06_I" sourceRef="Task_ShowErrorCode" targetRef="GW_MorePassengers" />
    <bpmn:sequenceFlow id="Flow_D_Loop" name="Next Passenger" sourceRef="GW_MorePassengers" targetRef="Task_EnterPassengerCode" />
    <bpmn:sequenceFlow id="Flow_D07_Done" name="Done" sourceRef="GW_MorePassengers" targetRef="End_ValidationComplete" />
  </bpmn:process>
  <bpmn:process id="Process_Admin" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Admin">
      <bpmn:lane id="Lane_System_Admin" name="System">
        <bpmn:flowNodeRef>Task_EnforceRBAC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ValidateInsertDB</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UpdateMaintenanceDates</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UpdateRentalStatusCar</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Admin_Portal" name="Admin">
        <bpmn:flowNodeRef>Start_LoginAdmin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ViewAdminDashboard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ManageBusFleet</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ManageUsers</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CreateDriverAccount</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ViewStatistics</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_AdminDone</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_ChangesApplied</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_AdminChooseAction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ManageRentalFleet</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ManageMaintenance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ManageRentalReturns</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_LoginAdmin" name="Login as Admin">
      <bpmn:outgoing>Flow_A01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_EnforceRBAC" name="Enforce RBAC&#10;(Admin role only)&#10;Unauthorised → Access Denied">
      <bpmn:incoming>Flow_A01</bpmn:incoming>
      <bpmn:outgoing>Flow_A02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ViewAdminDashboard" name="View Admin Dashboard&#10;KPIs: Total Bookings, Revenue (lek)&#10;Users, Buses, Active Rentals">
      <bpmn:incoming>Flow_A02</bpmn:incoming>
      <bpmn:incoming>Flow_A_Continue</bpmn:incoming>
      <bpmn:outgoing>Flow_A03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ManageBusFleet" name="Manage Bus Fleet&#10;(Add / View Buses)&#10;Bus Code, Plate, Model, Route">
      <bpmn:incoming>Flow_A_Bus</bpmn:incoming>
      <bpmn:outgoing>Flow_A_Bus_Sys</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ManageUsers" name="Manage Users&#10;(View All: Name, Email, Role&#10;Registration Date)">
      <bpmn:incoming>Flow_A_Users</bpmn:incoming>
      <bpmn:outgoing>Flow_A_Users_CreateDriver</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_CreateDriverAccount" name="Create Driver Account&#10;(Name, Email, Password&#10;bus_id, Route assigned)">
      <bpmn:incoming>Flow_A_Users_CreateDriver</bpmn:incoming>
      <bpmn:outgoing>Flow_A_Driver_Sys</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ViewStatistics" name="View Statistics Panel&#10;(Read-Only: Users, Bookings&#10;Revenue, Rentals, Buses)">
      <bpmn:incoming>Flow_01bpks8</bpmn:incoming>
      <bpmn:outgoing>Flow_A_Done4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_AdminDone" name="Done">
      <bpmn:incoming>Flow_A_Done1</bpmn:incoming>
      <bpmn:incoming>Flow_A_Done2</bpmn:incoming>
      <bpmn:incoming>Flow_A_Done3</bpmn:incoming>
      <bpmn:incoming>Flow_A_Done4</bpmn:incoming>
      <bpmn:outgoing>Flow_A_End</bpmn:outgoing>
      <bpmn:outgoing>Flow_A_Continue</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_ChangesApplied" name="Changes&#10;Applied">
      <bpmn:incoming>Flow_A_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_ValidateInsertDB" name="Validate Uniqueness&#10;Insert / Update DB Records&#10;(Reject duplicate code/plate)">
      <bpmn:incoming>Flow_A_Bus_Sys</bpmn:incoming>
      <bpmn:incoming>Flow_A_Rental_Sys</bpmn:incoming>
      <bpmn:incoming>Flow_A_Users_Sys</bpmn:incoming>
      <bpmn:incoming>Flow_A_Driver_Sys</bpmn:incoming>
      <bpmn:outgoing>Flow_A_Maint_Admin</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_UpdateMaintenanceDates" name="Update lastDate = today&#10;nextDate = lastDate + intervalDays&#10;Auto-recalculate all service types">
      <bpmn:incoming>Flow_A_Maint_Sys</bpmn:incoming>
      <bpmn:incoming>Flow_A_Maint_Admin</bpmn:incoming>
      <bpmn:outgoing>Flow_A_Done1</bpmn:outgoing>
      <bpmn:outgoing>Flow_1f5ymd9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_UpdateRentalStatusCar" name="Update Rentals status=&#39;completed&#39;&#10;Set car available=1&#10;(Also: daily checkRentals auto-job)">
      <bpmn:incoming>Flow_A_Return_Sys</bpmn:incoming>
      <bpmn:outgoing>Flow_A_Done2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_AdminChooseAction" name="Choose&#10;Action">
      <bpmn:incoming>Flow_A03</bpmn:incoming>
      <bpmn:outgoing>Flow_A_Bus</bpmn:outgoing>
      <bpmn:outgoing>Flow_A_Users</bpmn:outgoing>
      <bpmn:outgoing>Flow_A_Stats</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ManageRentalFleet" name="Manage Rental Fleet&#10;(Add / View Cars)&#10;available=1 on add">
      <bpmn:incoming>Flow_A_Stats</bpmn:incoming>
      <bpmn:outgoing>Flow_A_Rental_Sys</bpmn:outgoing>
      <bpmn:outgoing>Flow_01bpks8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ManageMaintenance" name="Manage Maintenance&#10;(Mark Services Done)&#10;Oil, Tyres, Brakes, Inspection">
      <bpmn:incoming>Flow_1f5ymd9</bpmn:incoming>
      <bpmn:outgoing>Flow_A_Maint_Sys</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ManageRentalReturns" name="Manage Rentals&#10;(Mark as Returned)&#10;Overdue rentals highlighted">
      <bpmn:incoming>Flow_A_Maint_Admin_R</bpmn:incoming>
      <bpmn:outgoing>Flow_A_Return_Sys</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_A01" sourceRef="Start_LoginAdmin" targetRef="Task_EnforceRBAC" />
    <bpmn:sequenceFlow id="Flow_A02" sourceRef="Task_EnforceRBAC" targetRef="Task_ViewAdminDashboard" />
    <bpmn:sequenceFlow id="Flow_A_Continue" name="Continue" sourceRef="GW_AdminDone" targetRef="Task_ViewAdminDashboard" />
    <bpmn:sequenceFlow id="Flow_A03" sourceRef="Task_ViewAdminDashboard" targetRef="GW_AdminChooseAction" />
    <bpmn:sequenceFlow id="Flow_A_Bus" name="Manage Bus Fleet" sourceRef="GW_AdminChooseAction" targetRef="Task_ManageBusFleet" />
    <bpmn:sequenceFlow id="Flow_A_Bus_Sys" sourceRef="Task_ManageBusFleet" targetRef="Task_ValidateInsertDB" />
    <bpmn:sequenceFlow id="Flow_A_Users" name="Manage Users" sourceRef="GW_AdminChooseAction" targetRef="Task_ManageUsers" />
    <bpmn:sequenceFlow id="Flow_A_Users_CreateDriver" sourceRef="Task_ManageUsers" targetRef="Task_CreateDriverAccount" />
    <bpmn:sequenceFlow id="Flow_A_Users_Sys" sourceRef="Task_ManageUsers" targetRef="Task_ValidateInsertDB" />
    <bpmn:sequenceFlow id="Flow_A_Driver_Sys" sourceRef="Task_CreateDriverAccount" targetRef="Task_ValidateInsertDB" />
    <bpmn:sequenceFlow id="Flow_01bpks8" sourceRef="Task_ManageRentalFleet" targetRef="Task_ViewStatistics" />
    <bpmn:sequenceFlow id="Flow_A_Done4" sourceRef="Task_ViewStatistics" targetRef="GW_AdminDone" />
    <bpmn:sequenceFlow id="Flow_A_Done1" sourceRef="Task_UpdateMaintenanceDates" targetRef="GW_AdminDone" />
    <bpmn:sequenceFlow id="Flow_A_Done2" sourceRef="Task_UpdateRentalStatusCar" targetRef="GW_AdminDone" />
    <bpmn:sequenceFlow id="Flow_A_Done3" sourceRef="Task_ValidateInsertDB" targetRef="GW_AdminDone" />
    <bpmn:sequenceFlow id="Flow_A_End" name="Done" sourceRef="GW_AdminDone" targetRef="End_ChangesApplied" />
    <bpmn:sequenceFlow id="Flow_A_Rental_Sys" sourceRef="Task_ManageRentalFleet" targetRef="Task_ValidateInsertDB" />
    <bpmn:sequenceFlow id="Flow_A_Maint_Admin" sourceRef="Task_ValidateInsertDB" targetRef="Task_UpdateMaintenanceDates" />
    <bpmn:sequenceFlow id="Flow_A_Maint_Admin_R" sourceRef="Task_ValidateInsertDB" targetRef="Task_ManageRentalReturns" />
    <bpmn:sequenceFlow id="Flow_A_Maint_Sys" sourceRef="Task_ManageMaintenance" targetRef="Task_UpdateMaintenanceDates" />
    <bpmn:sequenceFlow id="Flow_1f5ymd9" sourceRef="Task_UpdateMaintenanceDates" targetRef="Task_ManageMaintenance" />
    <bpmn:sequenceFlow id="Flow_A_Return_Sys" sourceRef="Task_ManageRentalReturns" targetRef="Task_UpdateRentalStatusCar" />
    <bpmn:sequenceFlow id="Flow_A_Stats" name="View Statistics" sourceRef="GW_AdminChooseAction" targetRef="Task_ManageRentalFleet" />
